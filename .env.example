# ==========================================
# AURA-26 STADIUM PULSE ENVIRONMENT SETTINGS
# ==========================================
# NOTE: Copy this file to '.env' and populate with valid credentials.
# NEVER commit the actual '.env' file to Git.

# Gemini API Key for structured GenAI decision engine
GEMINI_API_KEY=your_google_gemini_api_key_here

# Application Environment (development | production | staging)
APP_ENV=development

# Server Port and Host Configuration
PORT=8000
HOST=0.0.0.0

# Logging Level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Default Stadium Target for FIFA World Cup 2026
DEFAULT_STADIUM_ID=metlife_stadium_ny_nj
